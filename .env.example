# Concierge chatbot (Phase 3) — required for /api/chat
ANTHROPIC_API_KEY=

# Notion Leads database (Phase 2) — required to persist leads
NOTION_TOKEN=
NOTION_LEADS_DB_ID=

# Instant lead alert emails via Resend (Phase 4)
RESEND_API_KEY=
LEAD_ALERT_FROM=leads@barndobuilt.com
LEAD_ALERT_TO=handler@rebirthmultiverse.com

# Shared secret protecting the /api/batch/* endpoints (they spend API credits).
# Required — the batch routes return 503 until this is set.
BATCH_SECRET=

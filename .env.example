# Concierge chatbot (Phase 3) — required for /api/chat
ANTHROPIC_API_KEY=

# Notion Leads database (Phase 2) — required to persist leads
NOTION_TOKEN=
NOTION_LEADS_DB_ID=

# Instant lead alert emails via Resend (Phase 4)
RESEND_API_KEY=
LEAD_ALERT_FROM=leads@barndobuilt.com
LEAD_ALERT_TO=handler@rebirthmultiverse.com

# Shared secret protecting the /api/batch/* endpoints (they spend API credits).
# Required — the batch routes return 503 until this is set.
BATCH_SECRET=

# Audit mode — how the scheduled routines treat proposed changes.
#   manual      = routines email proposals; owner approves via Claude Max (default, safe)
#   autonomous  = routines commit changes directly + email what they did
# Circuit breakers (below) AUTO-FLIP autonomous → manual on drift.
AUDIT_MODE=manual

# Circuit-breaker thresholds. If ANY trips, audit mode auto-reverts to manual
# and the next daily-audit email opens with a RED card explaining which
# threshold tripped and which change to roll back.
AUDIT_FLIP_EVAL_DROP=0.3       # overall eval score drop between runs
AUDIT_FLIP_CONVERSION_DROP=0.3 # week-over-week conversion-rate drop (fraction)
AUDIT_FLIP_ANOMALY_DAYS=3      # consecutive daily-audits with anomalies
AUDIT_FLIP_HONESTY_FAIL=1      # any honesty-category lessons-learned entry
AUDIT_FLIP_RULES_PER_MONTH=5   # rate-limit autonomous prompt edits
